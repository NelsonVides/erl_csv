[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files_strict,
            rules => [
                %% This library intentionally uses macros for the single-byte
                %% CSV control tokens (separator, quotes, delimiter, ...).
                {elvis_style, no_macros, disable},
                %% Empty and control-character binaries read better as <<...>>.
                {elvis_style, prefer_sigils, disable}
            ]
        },
        #{
            files => ["include/**/*.hrl", "src/**/*.hrl"],
            ruleset => hrl_files,
            rules => [
                {elvis_style, no_macros, disable}
            ]
        },
        #{
            files => ["rebar.config"],
            ruleset => rebar_config
        }
    ]}
].
